# Azure SQL Database Configuration
# Copy this file to .env and fill in your Azure SQL credentials
# These variables should be set in your local .env file for testing
# and in GitHub Actions secrets for production workflows

# Azure SQL Server hostname (without .database.windows.net prefix)
# Example: myserver
AZURE_SQL_SERVER=

# Azure SQL Database name
# Example: cryptopp
AZURE_SQL_DATABASE=

# Azure AD Service Principal Client ID (Application ID)
# This is the app registration ID used for authentication
AZURE_SQL_CLIENT_ID=

# Azure AD Service Principal Client Secret
# This is the password/secret for the app registration
# WARNING: Never commit this to version control!
AZURE_SQL_CLIENT_SECRET=

# Azure AD Tenant ID
# This is the directory ID of your Azure AD tenant
AZURE_SQL_TENANT_ID=

# Optional: ODBC Driver version (leave as default if using ODBC Driver 18)
# Options: "ODBC Driver 17 for SQL Server" or "ODBC Driver 18 for SQL Server"
# Default: ODBC Driver 18 for SQL Server (not needed to set if using ODBC 18)
